# MewCode 配置文件（含敏感凭据，禁止提交）
mewcode.yaml

# Python 缓存与构建产物
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# 虚拟环境
.venv/
venv/
env/

# 测试与覆盖率
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp
*~

# EasyCode 临时文件（截图剪贴板等），保留 settings.json
.easycode/clipboard/
.easycode/cache/
.easycode/logs/

# 第五阶段权限系统：本地规则文件（不应入 git，可能含敏感命令开放）
.mewcode/permissions.local.yaml

# 第六阶段 MCP：预留本地 MCP 配置（可能含本机路径/私有 Server）
.mewcode/mcp_servers.local.yaml

# 第八阶段上下文压缩：工具结果存盘目录（含每次会话的大型 tool_result）
.mewcode/transcripts/
